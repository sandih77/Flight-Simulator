build/
Build/
build-*/

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# vcpkg
vcpkg_installed/

# Éditeurs de texte (VS Code)
# NOTE : On ignore .vscode pour ne pas partager tes chemins Debian locaux (/usr/include/qt6...) 
# avec des collaborateurs qui seraient sous Windows ou Mac.
.vscode/