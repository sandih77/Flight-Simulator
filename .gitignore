# ==========================================
# Spécifique à ton projet (build.sh & IDE)
# ==========================================

# L'exécutable généré par ton script build.sh
flight_simulator

# Le fichier texte temporaire généré par ton build.sh
source.txt

# Les fichiers générés par le MOC de Qt
# (Indispensable pour éviter de polluer ton dépôt Git avec du code généré automatiquement)
moc_*.cpp
src/**/moc_*.cpp
include/**/moc_*.cpp


